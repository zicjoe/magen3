# Frontend
VITE_API_URL=http://localhost:8787
VITE_CASPER_NETWORK=casper-testnet
VITE_CASPER_RPC_URL=https://node.testnet.casper.network/rpc
VITE_MAGEN3_CONTRACT_HASH=hash-b08ae51143e0d2fa78761e7819010e4c941dba3734252cdcf28ea7176cd4abcf

# Backend
BACKEND_PORT=8787
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Railway / PostgreSQL
# Required for real data. Magen3 will not use temporary storage unless ALLOW_MEMORY_STORE=true.
DATABASE_URL=

# For most hosted Postgres providers, true works. For local Postgres, use false.
DATABASE_SSL=true

# Casper Testnet audit recording
CASPER_NETWORK=casper-testnet
CASPER_CHAIN_NAME=casper-test
CASPER_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_RECORDING_MODE=manual-real-deploy
MAGEN3_CONTRACT_HASH=hash-b08ae51143e0d2fa78761e7819010e4c941dba3734252cdcf28ea7176cd4abcf

# Local Casper deploy helper only. Never commit real key files.
CASPER_SECRET_KEY_PATH=~/magen3-keys/secret_key.pem
CASPER_INSTALL_PAYMENT_MOTES=150000000000
CASPER_CALL_PAYMENT_MOTES=5000000000

# Agent Gateway API
# Set this in Railway to require external agents to authenticate before submitting intents.
AGENT_GATEWAY_API_KEY=

# Optional local-only escape hatch. Do not set this on Railway for the real demo.
ALLOW_MEMORY_STORE=false
