# Frontend
VITE_API_URL=http://localhost:8787
VITE_CASPER_NETWORK=casper-testnet
VITE_CASPER_RPC_URL=https://rpc.testnet.casper.network/rpc
VITE_MAGEN3_CONTRACT_HASH=

# Backend
BACKEND_PORT=8787
CORS_ORIGIN=http://localhost:5173

# Railway / PostgreSQL
# Leave DATABASE_URL empty for local in-memory mode.
# Add Railway Postgres DATABASE_URL here when you are ready for persistent storage.
DATABASE_URL=

# For most hosted Postgres providers, true works. For local Postgres, use false.
DATABASE_SSL=true
