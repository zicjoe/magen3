{
  "name": "magen3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "node backend/server.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "api:health": "node -e \"fetch('http://localhost:8787/api/health').then(r=>r.json()).then(console.log).catch(console.error)\"",
    "db:migrate": "node backend/db/migrate.mjs",
    "railway:start": "node backend/server.mjs",
    "start": "node backend/server.mjs",
    "backend:start": "node backend/server.mjs",
    "contract:build": "cargo +nightly-2024-08-01 build --manifest-path contracts/magen3-audit-registry/Cargo.toml --target wasm32-unknown-unknown --release",
    "contract:check": "node scripts/casper/check-contract-wasm.mjs",
    "casper:install:cmd": "node scripts/casper/print-install-command.mjs",
    "casper:record:cmd": "node scripts/casper/print-record-command.mjs",
    "contract:clean": "cargo clean --manifest-path contracts/magen3-audit-registry/Cargo.toml",
    "contract:doctor": "node scripts/casper/contract-doctor.mjs",
    "rust:prepare": "rustup toolchain install nightly-2024-08-01 && rustup target add wasm32-unknown-unknown --toolchain nightly-2024-08-01",
    "agent:test": "node examples/real-agent-client/index.mjs",
    "agent:test:safe": "node examples/real-agent-client/index.mjs --scenario=safe",
    "agent:test:risky": "node examples/real-agent-client/index.mjs --scenario=risky",
    "agent:test:review": "node examples/real-agent-client/index.mjs --scenario=review",
    "agent:test:oracle": "node examples/real-agent-client/index.mjs --scenario=oracle"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "1.2.14",
    "@radix-ui/react-alert-dialog": "1.1.17",
    "@radix-ui/react-aspect-ratio": "1.1.10",
    "@radix-ui/react-avatar": "1.2.0",
    "@radix-ui/react-checkbox": "1.3.5",
    "@radix-ui/react-collapsible": "1.1.14",
    "@radix-ui/react-context-menu": "2.3.1",
    "@radix-ui/react-dialog": "1.1.17",
    "@radix-ui/react-dropdown-menu": "2.1.18",
    "@radix-ui/react-hover-card": "1.1.17",
    "@radix-ui/react-label": "2.1.10",
    "@radix-ui/react-menubar": "1.1.18",
    "@radix-ui/react-navigation-menu": "1.2.16",
    "@radix-ui/react-popover": "1.1.17",
    "@radix-ui/react-progress": "1.1.10",
    "@radix-ui/react-radio-group": "1.4.1",
    "@radix-ui/react-scroll-area": "1.2.12",
    "@radix-ui/react-select": "2.3.1",
    "@radix-ui/react-separator": "1.1.10",
    "@radix-ui/react-slider": "1.4.1",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.1",
    "@radix-ui/react-tabs": "1.1.15",
    "@radix-ui/react-toggle": "1.1.12",
    "@radix-ui/react-toggle-group": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.10",
    "casper-js-sdk": "^2.15.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "drizzle-orm": "0.44.7",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "1.21.0",
    "next-themes": "0.4.6",
    "pg": "8.16.3",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "react-resizable-panels": "4.11.2",
    "recharts": "3.9.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "drizzle-kit": "0.31.7",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  }
}
